        "postContent": "<!-- wp:generateblocks/container {\"uniqueId\":\"5a6344a3\",\"backgroundColor\":\"#000000\",\"bgImage\":{\"id\":\"\",\"image\":{\"url\":\"https://lestatic.b-cdn.net/lisboaeventsmainvideo.png\",\"height\":1080,\"width\":1920,\"orientation\":\"landscape\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.22,\"overlay\":false,\"position\":\"center center\",\"size\":\"cover\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"spacing\":{\"paddingTop\":\"100px\",\"paddingBottom\":\"100px\"}} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"e7f79de8\",\"backgroundColor\":\"#ffffff\",\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"zindex\":9,\"useGlobalMaxWidth\":true,\"spacing\":{\"marginRight\":\"auto\",\"marginLeft\":\"auto\",\"paddingTop\":\"50px\",\"paddingBottom\":\"50px\",\"paddingLeft\":\"30px\",\"paddingRight\":\"30px\",\"paddingLeftMobile\":\"\",\"marginLeftMobile\":\"15px\",\"marginRightMobile\":\"15px\"}} -->\n<!-- wp:generateblocks/headline {\"uniqueId\":\"12e30ab2\",\"element\":\"h1\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontWeight\":\"700\",\"fontSize\":\"34px\"},\"textColor\":\"#333333\"} -->\n<h1 class=\"gb-headline gb-headline-12e30ab2 gb-headline-text\">Advertise with us</h1>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"11f06b28\",\"textColor\":\"#375e97\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"maxWidth\":\"15%\",\"maxHeight\":\"\"},\"spacing\":{\"marginTop\":\"0px\",\"marginBottom\":\"0px\",\"marginLeft\":\"auto\",\"marginRight\":\"auto\",\"paddingTop\":\"\"}} -->\n<!-- wp:separator {\"className\":\"brder-line\",\"backgroundColor\":\"accent\"} -->\n<hr class=\"wp-block-separator has-text-color has-accent-color has-alpha-channel-opacity has-accent-background-color has-background brder-line\"/>\n<!-- /wp:separator -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/headline {\"uniqueId\":\"49c0c512\",\"element\":\"h4\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontSizeMobile\":\"20px\"},\"spacing\":{\"paddingLeft\":\"160px\",\"paddingRight\":\"160px\",\"marginTop\":\"-30px\",\"paddingLeftMobile\":\"0px\",\"paddingRightMobile\":\"0px\"}} -->\n<h4 class=\"gb-headline gb-headline-49c0c512 gb-headline-text\">Léman Events is the most cost-effective channel for direct conversions, B2C lead generation and brand awareness among a highly targeted audience of parents of 0-12 yo in the Lake Geneva region (mainly mothers).</h4>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/headline {\"uniqueId\":\"17689cb1\",\"element\":\"h4\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontSize\":\"16px\",\"fontWeight\":\"400\"},\"spacing\":{\"paddingLeft\":\"200px\",\"paddingRight\":\"200px\",\"marginTop\":\"\",\"paddingLeftMobile\":\"0px\",\"paddingRightMobile\":\"0px\",\"paddingBottom\":\"\"},\"textColor\":\"#333333\"} -->\n<h4 class=\"gb-headline gb-headline-17689cb1 gb-headline-text\">Please leave us your contact information and we will get back to you in 1-2 business days with our media kit for advertisers that details placements, costs and the process.</h4>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"b9163be5\",\"isDynamic\":true,\"blockVersion\":4,\"spacing\":{\"paddingLeft\":\"30px\",\"paddingRight\":\"30px\",\"paddingLeftMobile\":\"0px\",\"paddingRightMobile\":\"0px\",\"paddingTop\":\"20px\"}} -->\n<!-- wp:columns -->\n<div class=\"wp-block-columns\"><!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:generateblocks/container {\"uniqueId\":\"d87fe377\",\"isDynamic\":true,\"blockVersion\":4,\"spacing\":{\"paddingRight\":\"30px\",\"paddingRightMobile\":\"0px\"}} -->\n<!-- wp:columns {\"verticalAlignment\":\"top\",\"isStackedOnMobile\":false} -->\n<div class=\"wp-