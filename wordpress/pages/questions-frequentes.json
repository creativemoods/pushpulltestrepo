        "postContent": "<!-- wp:generateblocks/container {\"uniqueId\":\"5a6344a3\",\"backgroundColor\":\"#000000\",\"bgImage\":{\"id\":\"\",\"image\":{\"url\":\"https://lestatic.b-cdn.net/lisboaeventsmainvideo.png\",\"height\":1080,\"width\":1920,\"orientation\":\"landscape\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.22,\"overlay\":false,\"position\":\"center center\",\"size\":\"cover\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"spacing\":{\"paddingTop\":\"100px\",\"paddingBottom\":\"100px\"}} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"e7f79de8\",\"backgroundColor\":\"#ffffff\",\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"zindex\":9,\"useGlobalMaxWidth\":true,\"spacing\":{\"marginRight\":\"auto\",\"marginLeft\":\"auto\",\"paddingTop\":\"50px\",\"paddingBottom\":\"50px\",\"paddingLeft\":\"30px\",\"paddingRight\":\"30px\",\"paddingLeftMobile\":\"\",\"marginLeftMobile\":\"15px\",\"marginRightMobile\":\"15px\"}} -->\n<!-- wp:generateblocks/headline {\"uniqueId\":\"12e30ab2\",\"element\":\"h1\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontWeight\":\"700\",\"fontSize\":\"34px\"},\"textColor\":\"#333333\"} -->\n<h1 class=\"gb-headline gb-headline-12e30ab2 gb-headline-text\">Questions fréquentes</h1>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"11f06b28\",\"textColor\":\"#375e97\",\"isDynamic\":true,\"blockVersion\":4,\"sizing\":{\"maxWidth\":\"15%\",\"maxHeight\":\"\"},\"spacing\":{\"marginTop\":\"0px\",\"marginBottom\":\"0px\",\"marginLeft\":\"auto\",\"marginRight\":\"auto\",\"paddingTop\":\"\"}} -->\n<!-- wp:separator {\"className\":\"brder-line\",\"backgroundColor\":\"accent\"} -->\n<hr class=\"wp-block-separator has-text-color has-accent-color has-alpha-channel-opacity has-accent-background-color has-background brder-line\"/>\n<!-- /wp:separator -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/headline {\"uniqueId\":\"49c0c512\",\"element\":\"h4\",\"blockVersion\":3,\"typography\":{\"textAlign\":\"center\",\"fontSizeMobile\":\"20px\"},\"spacing\":{\"paddingLeft\":\"160px\",\"paddingRight\":\"160px\",\"marginTop\":\"-30px\",\"paddingLeftMobile\":\"0px\",\"paddingRightMobile\":\"0px\"}} -->\n<h4 class=\"gb-headline gb-headline-49c0c512 gb-headline-text\">Avez-vous des questions ? Avant de nous contacter, nous vous recommandons de consulter attentivement notre section FAQ. Il est possible que les informations que vous recherchez y soient déjà disponibles.</h4>\n<!-- /wp:generateblocks/headline -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"8c0b2148\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"spacing\":{\"marginTop\":\"50px\"}} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"10633a86\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion\",\"backgroundColorHover\":\"var(u002du002dbase-3)\",\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/container {\"uniqueId\":\"51ad051a\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"7831e183\",\"anchor\":\"gb-accordion-toggle-7831e183\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"var(\\u002d\\u002dbase-3)\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-7831e183 gb-accordion__toggle\" id=\"gb-accordion-toggle-7831e183\"><span class=\"gb-button-text\">Comment mon événement/mon camp/mon entreprise peuvent-ils être mis en avant dans la newsletter ?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"2a797221\",\"anchor\":\"gb-accordion-content-2a797221\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">Si vous souhaitez faire de la publicité via le canal le plus rentable pour des conversions directes, la génération de leads B2C et la notoriété de marque auprès d'un public ciblé de parents d'enfants de 0 à 12 ans sur l'arc lémanique (principalement des mères), veuillez écrire à hello@leman.events ou laissez-nous vos coordonnées en utilisant la page <a href=\"{{pushpull.home_url}}/fr/promouvoir/\" title=\"Promouvoir\">Promouvoir</a>. Nous vous répondrons dans 1 à 2 jours ouvrables et serons très heureux de vous envoyer notre kit média pour annonceurs.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"15dbe0ca\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"ef06d70b\",\"anchor\":\"gb-accordion-toggle-ef06d70b\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"var(\\u002d\\u002dbase-3)\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-ef06d70b gb-accordion__toggle\" id=\"gb-accordion-toggle-ef06d70b\"><span class=\"gb-button-text\">Puis-je suggérer un événement/un camp et quel est le processus ?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"aafea4d1\",\"anchor\":\"gb-accordion-content-aafea4d1\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">Si vous connaissez un événement/un camp que nous aurions pu manquer, n'hésitez pas à nous envoyer un lien. Nous ferons de notre mieux pour l'inclure dans la newsletter. Veuillez consulter la page <a href=\"{{pushpull.home_url}}/fr/partager-un-evenement/\" title=\"Partager un événement\">Partager un événement</a>.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"0b81edc6\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"0d5184d9\",\"anchor\":\"gb-accordion-toggle-0d5184d9\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"var(\\u002d\\u002dbase-3)\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-0d5184d9 gb-accordion__toggle\" id=\"gb-accordion-toggle-0d5184d9\"><span class=\"gb-button-text\">Mon adresse e-mail et mes données personnelles peuvent-elles être partagées avec des tiers ?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"95dbdeaa\",\"anchor\":\"gb-accordion-content-95dbdeaa\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">Nous ne vendons, n'échangeons ni ne transférons autrement vos informations personnelles à des tiers. Notre Politique de confidentialité décrit comment Léman Events collecte, utilise, divulgue et protège les informations personnelles des utilisateurs qui accèdent et interagissent avec notre newsletter. Veuillez consulter la page <a href=\"{{pushpull.home_url}}/fr/politique-de-confidentialite/\" title=\"Politique de confidentialité\">Politique de confidentialité</a>.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"db318b88\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"cff2c0de\",\"anchor\":\"gb-accordion-toggle-cff2c0de\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"var(\\u002d\\u002dbase-3)\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-cff2c0de gb-accordion__toggle\" id=\"gb-accordion-toggle-cff2c0de\"><span class=\"gb-button-text\">Comment puis-je me désabonner ?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z\" fill=\"currentColor\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon-open\"><path d=\"M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z\" fill=\"currentColor\"></path></svg></span></button>\n<!-- /wp:generateblocks/button -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"f551f343\",\"anchor\":\"gb-accordion-content-f551f343\",\"backgroundColor\":\"var(u002du002dbase-3)\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-content\",\"spacing\":{\"paddingTop\":\"20px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"20px\",\"paddingLeft\":\"20px\",\"marginBottom\":\"20px\"}} -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"#8b8494\"},\"elements\":{\"link\":{\"color\":{\"text\":\"#8b8494\"}}},\"typography\":{\"fontStyle\":\"normal\",\"fontWeight\":\"400\",\"fontSize\":\"16px\"}}} -->\n<p class=\"has-text-color has-link-color\" style=\"color:#8b8494;font-size:16px;font-style:normal;font-weight:400\">Êtes-vous sûr(e) de vouloir nous quitter ? Nous sommes désolés de vous voir partir ! Si vous ne souhaitez plus recevoir les prochaines éditions de Léman Events, cliquez sur le lien de désinscription à la toute fin de la newsletter. Merci de nous faire savoir pourquoi vous vous désabonnez ou ce que nous pourrions améliorer.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:generateblocks/container -->\n<!-- /wp:generateblocks/container -->\n\n<!-- wp:generateblocks/container {\"uniqueId\":\"068c86a6\",\"isDynamic\":true,\"blockVersion\":4,\"variantRole\":\"accordion-item\",\"useTransition\":true,\"transitions\":[{\"state\":\"normal\",\"target\":\"accordionContent\",\"customSelector\":\"\",\"timingFunction\":\"ease\",\"delay\":\"\",\"property\":\"max-height\",\"duration\":0.25}],\"accordionTransition\":\"slide\"} -->\n<!-- wp:generateblocks/button {\"uniqueId\":\"d5df3be6\",\"anchor\":\"gb-accordion-toggle-d5df3be6\",\"blockVersion\":4,\"variantRole\":\"accordion-toggle\",\"buttonType\":\"button\",\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"space-between\",\"columnGap\":\"0.5em\",\"sizing\":{\"width\":\"100%\"},\"typography\":{\"textAlign\":\"left\",\"fontSize\":\"20px\",\"fontWeight\":\"500\"},\"spacing\":{\"paddingTop\":\"15px\",\"paddingRight\":\"20px\",\"paddingBottom\":\"15px\",\"paddingLeft\":\"20px\"},\"backgroundColor\":\"var(u002du002dbase-3)\",\"backgroundColorHover\":\"#ffffff\",\"backgroundColorCurrent\":\"var(u002du002dbase-3)\",\"textColor\":\"var(\\u002d\\u002dbase-3)\",\"textColorHover\":\"#333333\",\"textColorCurrent\":\"#333333\",\"hasIcon\":true,\"iconLocation\":\"right\",\"iconPaddingRight\":\"\",\"iconStyles\":{\"width\":\"0.8em\",\"height\":\"0.8em\"}} -->\n<button class=\"gb-button gb-button-d5df3be6 gb-accordion__toggle\" id=\"gb-accordion-toggle-d5df3be6\"><span class=\"gb-button-text\">Dans quelle langue est la newsletter ?</span><span class=\"gb-icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" role=\"img\" class=\"gb-accordion__icon\"><path d=\"M207.029 381.476L12.686 187.132c-9.3